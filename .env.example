# Telegram Bot Token (get from @BotFather on Telegram)
BOT_TOKEN=your_bot_token_here

# Database URL (Neon PostgreSQL)
# Formato: postgresql://user:password@ep-xxx.region.neon.tech/dbname?sslmode=require
DATABASE_URL=your_database_url_here

# App mode: "webhook" for production (Render), "polling" for local dev
BOT_MODE=polling

# Webhook URL (only needed if BOT_MODE=webhook AND not using Render)
# Render sets RENDER_EXTERNAL_URL automatically, so you don't need this on Render.
# WEBHOOK_URL=https://your-app.onrender.com

# Server port (Render sets PORT automatically)
PORT=3000
